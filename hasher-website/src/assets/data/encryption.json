  "theory": {
    "aes": [
      {
        "title": "Mechanika działania",
        "content": "AES to standardowy szyfr blokowy używany do szybkiego i bezpiecznego szyfrowania danych. Warianty GCM, CBC i CTR różnią się głównie sposobem użycia IV, nonce i uwierzytelniania."
      },
      {
        "title": "Historia",
        "content": "Został wybrany w drodze konkursu ogłoszonego przez NIST w 1997 roku i oficjalnie zatwierdzony jako standard w 2001 roku, zastępując wysłużony algorytm DES."
      },
      {
        "title": "Zastosowanie",
        "content": "AES jest dobrym wyborem do plików, transmisji i lokalnego przechowywania danych. W praktyce klucz jest najważniejszym sekretem, a nonce lub IV bywają jawne, jednak ich unikalność i poprawne dobranie do trybu pracy są absolutnie kluczowe dla bezpieczeństwa."
      }
    ],
    "chacha": [
      {
        "title": "Mechanika działania",
        "content": "ChaCha20 to szybki szyfr strumieniowy, który miesza klucz, nonce i licznik w kolejne bloki keystreamu, a potem XOR-uje je z danymi."
      },
      {
        "title": "Historia",
        "content": "ChaCha20 został zaprojektowany jako praktyczna alternatywa dla AES na sprzęcie bez akceleracji, szczególnie na urządzeniach mobilnych i w środowiskach programowych."
      },
      {
        "title": "Zastosowanie",
        "content": "ChaCha20 jest często używany w nowoczesnych protokołach sieciowych, gdzie liczy się wydajność i odporność na różnice sprzętowe."
      }
    ],
    "rsa": [
      {
        "title": "Mechanika działania",
        "content": "RSA wykorzystuje parę kluczy: publiczny do szyfrowania i prywatny do odszyfrowania. Bezpieczeństwo opiera się na trudności rozkładu dużych liczb na czynniki pierwsze."
      },
      {
        "title": "Historia",
        "content": "RSA został opisany w 1977 roku przez Rivesta, Shamira i Adlemana i stał się jednym z najważniejszych algorytmów kryptografii asymetrycznej."
      },
      {
        "title": "Zastosowanie",
        "content": "RSA jest szeroko stosowany w podpisach cyfrowych, wymianie kluczy i starszych wdrożeniach szyfrowania, gdzie kompatybilność bywa ważniejsza niż wydajność."
      }
    ],
    "ecc": [
      {
        "title": "Mechanika działania",
        "content": "ECC opiera się na arytmetyce krzywych eliptycznych i umożliwia osiągnięcie wysokiego poziomu bezpieczeństwa przy krótszych kluczach niż RSA."
      },
      {
        "title": "Historia",
        "content": "Kryptografia eliptyczna zyskała popularność, gdy okazało się, że może dawać podobny poziom ochrony przy mniejszym koszcie obliczeniowym i pamięciowym."
      },
      {
        "title": "Zastosowanie",
        "content": "ECC jest wykorzystywany w podpisach, wymianie kluczy i systemach, gdzie ważne są krótkie klucze oraz dobra wydajność na ograniczonym sprzęcie."
      }
    ],
    "aes_gcm": [
      {
        "title": "Mechanika działania",
        "content": "AES działa jako szyfr blokowy z siecią podstawień i permutacji. Dane są dzielone na bloki 128-bitowe, a kolejne rundy mieszają je z kluczem w kontrolowany sposób."
      },
      {
        "title": "Historia",
        "content": "AES został wybrany w konkursie NIST i standaryzowany w 2001 roku jako następca DES. Do dziś jest podstawą wielu współczesnych protokołów bezpieczeństwa."
      },
      {
        "title": "Zastosowanie",
        "content": "AES jest używany w VPN-ach, dyskach szyfrowanych, komunikacji HTTPS i wszędzie tam, gdzie potrzebne jest szybkie i silne szyfrowanie symetryczne."
      }
    ]
  }
